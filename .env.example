# Public env vars consumed by the browser bundle (PUBLIC_ prefix required by
# SvelteKit). Copy to .env and adjust per environment.

# OSRM routing endpoint. Defaults to the public demo at
# https://router.project-osrm.org when unset. Point this at a self-hosted
# osrm-routed Docker container for reliable sketch matching — the demo
# rejects dense traces with "TooBig — Radius search size is too large"
# when PUBLIC_OSRM_MATCH_RADIUS exceeds its server-side cap.
PUBLIC_OSRM_BASE_URL=http://localhost:5050