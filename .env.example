# OSRM upstream for POST /api/route (server-only).
# Default: FOSSGIS public bike graph (fair use: ≤1 req/s, valid User-Agent).
# https://routing.openstreetmap.de/about.html
OSRM_BASE_URL=https://routing.openstreetmap.de/routed-bike

# Path profile segment under the base. FOSSGIS routed-bike uses `driving`
# in the URL even though the graph is bicycle-weighted.
OSRM_PROFILE=driving
