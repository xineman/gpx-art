# Public env vars consumed by the browser bundle (PUBLIC_ prefix required by
# SvelteKit). Copy to .env and adjust per environment.

# OSRM routing endpoint. Defaults to the FOSSGIS public bike instance
# (https://routing.openstreetmap.de/routed-bike) when unset — that serves a
# real bicycle profile. Do NOT use https://router.project-osrm.org: it only
# has car data, so /route/v1/bike/... still returns driving routes.
# Point this at a self-hosted osrm-routed (bicycle.lua extract) for reliable
# local routing without FOSSGIS rate limits.
PUBLIC_OSRM_BASE_URL=http://localhost:5050
